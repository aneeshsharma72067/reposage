{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npx prisma generate --schema=prisma/schema.prisma && npm run build",
    "functions": {
        "api/index.ts": {
            "maxDuration": 30,
            "includeFiles": "prisma/**"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.ts"
        }
    ]
}